generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  ADMIN
  SUPERVISOR
  LEAD
  ARTIST
}

enum UpdateStatus {
  WIP
  HOLD
  REVIEW
  APPROVED
}

model User {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  password  String
  role      UserRole

  updates   DailyUpdate[]

  createdAt DateTime @default(now())
}

model Project {
  id          String   @id @default(cuid())
  name        String
  code        String   @unique
  description String?

  shots       Shot[]

  createdAt   DateTime @default(now())
}

model Shot {
  id          String   @id @default(cuid())
  shotName    String

  projectId   String
  project      Project @relation(fields: [projectId], references: [id])

  updates     DailyUpdate[]

  createdAt   DateTime @default(now())
}

model DailyUpdate {
  id          String   @id @default(cuid())

  userId      String
  user         User @relation(fields: [userId], references: [id])

  shotId      String
  shot         Shot @relation(fields: [shotId], references: [id])

  hours       Float
  status      UpdateStatus
  comments    String?

  createdAt   DateTime @default(now())
}