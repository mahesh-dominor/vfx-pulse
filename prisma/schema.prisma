generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String        @id @default(cuid())
  name      String
  email     String        @unique
  password  String
  role      UserRole      @default(ARTIST)
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  updates   DailyUpdate[]
}

model Project {
  id          String   @id @default(cuid())
  name        String
  code        String   @unique
  description String?
  createdAt   DateTime @default(now())
  shots       Shot[]
}

model Shot {
  id        String        @id @default(cuid())
  shotName  String
  projectId String
  createdAt DateTime      @default(now())
  updates   DailyUpdate[]
  project   Project       @relation(fields: [projectId], references: [id])
}

model DailyUpdate {
  id        String       @id @default(cuid())
  userId    String
  shotId    String
  hours     Float
  status    UpdateStatus
  comments  String?
  createdAt DateTime     @default(now())
  shot      Shot         @relation(fields: [shotId], references: [id])
  user      User         @relation(fields: [userId], references: [id])
}

enum UserRole {
  ADMIN
  SUPERVISOR
  LEAD
  ARTIST
}

enum UpdateStatus {
  WIP
  HOLD
  REVIEW
  APPROVED
}
