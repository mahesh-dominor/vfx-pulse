# App
NODE_ENV=development
PORT=3000
NEXT_PUBLIC_APP_URL=http://localhost:3000
# Production example:
# NEXT_PUBLIC_APP_URL=https://mrvfxpulse.com

# Auth
AUTH_SECRET=replace-with-long-random-secret
AUTH_URL=http://localhost:3000
# Production example:
# AUTH_URL=https://mrvfxpulse.com

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/vfxpulse?schema=public

# Optional email provider placeholders
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=no-reply@vfxpulse.local
