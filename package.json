{
  "name": "vfx-pulse",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "postinstall": "prisma generate",
    "start": "next start",
    "lint": "eslint .",
    "type-check": "tsc --noEmit",
    "prisma:validate": "prisma validate",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:reset": "prisma migrate reset",
    "prisma:studio": "prisma studio",
    "prisma:seed": "tsx prisma/seed.ts",
    "prisma:deploy": "prisma migrate deploy",
    "deploy:db": "npm run prisma:generate && npm run prisma:deploy && npm run prisma:seed",
    "deploy:vercel": "npm run prisma:generate && npm run build",
    "verify:release": "npm run prisma:validate && npm run prisma:generate && npm run type-check && npm run lint && npm run build",
    "release:prepare": "npm run verify:release && npm run docs:check",
    "docs:check": "node scripts/docs-check.mjs"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
